{
  "schemaVersion": 1,
  "project": {
    "name": "My Project",
    "graphOutput": "graph.json"
  },
  "sourceRoots": {
    "frontend": "src",
    "backend": "api"
  },
  "templates": {
    "enabled": [
      "filesystem",
      "typescript",
      "react",
      "architecture.feature-sliced",
      "architecture.mvvm",
      "http-endpoints",
      "dotnet-api",
      "architecture.mvc",
      "architecture.clean-architecture",
      "architecture.cqrs",
      "entity-framework",
      "coverage",
      "quality"
    ]
  },
  "imports": {
    "aliases": [
      {
        "prefix": "@/",
        "path": "src"
      }
    ]
  },
  "modules": {
    "shared": "shared",
    "labels": {}
  },
  "frontend": {
    "entryPoints": []
  },
  "rules": {
    "options": {
      "framework.react.component-max-lines": {
        "max": 200
      }
    }
  },
  "backend": {}
}
