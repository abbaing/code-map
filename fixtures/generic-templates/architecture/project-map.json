{
  "schemaVersion": 1,
  "project": {
    "name": "Architecture Fixture",
    "graphOutput": "fixtures/generic-templates/architecture/graph.json",
    "runtimeLinks": "runtime-links.json"
  },
  "sourceRoots": {
    "frontend": "fixtures/generic-templates/architecture/front/src",
    "backend": "fixtures/generic-templates/architecture/back"
  },
  "templates": {
    "enabled": [
      "filesystem",
      "typescript",
      "react",
      "architecture.feature-sliced",
      "architecture.mvvm",
      "dotnet-api",
      "architecture.mvc",
      "architecture.clean-architecture",
      "quality"
    ]
  },
  "imports": {
    "aliases": [
      { "prefix": "@/", "path": "fixtures/generic-templates/architecture/front/src" }
    ]
  },
  "modules": {
    "shared": "shared",
    "frontendFeaturePattern": "^fixtures/generic-templates/architecture/front/src/features/([^/]+)",
    "backendProjectFolderPattern": "^fixtures/generic-templates/architecture/back/[^/]+/([^/]+)",
    "backendControllerPattern": "^fixtures/generic-templates/architecture/back/[^/]+/Controllers/(.+?)Controller\\.cs$",
    "backendEntityDomainPattern": "^fixtures/generic-templates/architecture/back/[^/]+/Entities/([^/]+)",
    "labels": {}
  },
  "layers": [
    { "id": "ui-component-logic", "label": "Components" },
    { "id": "ui-main-component", "label": "Main Components" },
    { "id": "front-repository", "label": "Repositories" },
    { "id": "api-controller", "label": "Controllers" },
    { "id": "domain", "label": "Domain" }
  ],
  "frontend": {
    "entryPoints": [],
    "featureFolderPattern": "/features/{module}/",
    "classifiers": [
      { "contains": "/repositories/", "type": "repository", "layer": "front-repository" }
    ],
    "coverableTypes": []
  },
  "rules": {
    "enabled": [
      "framework.react.component-folder-entry",
      "architecture.mvvm.thin-view-entry",
      "architecture.feature-sliced.no-cross-feature-internals",
      "architecture.mvvm.viewmodel-hook-naming",
      "architecture.layered.no-ui-imports-in-data-adapters",
      "architecture.mvc.thin-controller",
      "architecture.clean-architecture.layer-boundaries"
    ],
    "options": {
      "framework.react.component-folder-entry": {
        "includePatterns": ["^fixtures/generic-templates/architecture/front/src/features/[^/]+/components/"]
      },
      "architecture.clean-architecture.layer-boundaries": {
        "namespacePrefix": "Demo"
      }
    },
    "suppressions": []
  },
  "backend": {
    "entryPointSuffixes": ["/Program.cs"],
    "dtoPathFragment": "/DTOs/",
    "validatorPathFragment": "/Validators/",
    "mappingPathFragment": "/Mappings/",
    "controllerPathFragment": "/Controllers/",
    "handlerPathFragment": "/Handlers/",
    "repositoryPathFragment": "/Repositories/",
    "entityConfigurationPathFragment": "/Configurations/Entities/",
    "dataContextPathFragment": "/Data/Context/",
    "entityPathFragment": "/Entities/",
    "classifiers": [
      { "contains": "/Controllers/", "type": "controller", "layer": "api-controller" },
      { "contains": "/Entities/", "type": "entity", "layer": "domain" }
    ]
  }
}
